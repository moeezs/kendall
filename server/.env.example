GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID — only this account can talk to the bot.
# Find yours by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# The Tauri app identifier from src-tauri/tauri.conf.json (the "identifier" field).
# This is used to locate the Kendall database on your machine.
# Default: com.moeez.kendall
KENDALL_APP_ID=com.moeez.kendall

# Optional: override the full database path directly (overrides KENDALL_APP_ID).
# DB_PATH=/path/to/your/kendall.db
